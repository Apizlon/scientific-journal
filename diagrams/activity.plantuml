@startuml
title 2.2 Диаграмма деятельности — оформление заказа (checkout)

start
:Пользователь авторизован;
:Открывает "Корзина";
if (Корзина пуста?) then (да)
  :Показать "Корзина пуста";
  stop
else (нет)
  :Показать список выпусков и итоговую сумму;
  :Нажать "Оформить заказ";
  :Создать запись orders\n(status="pending", total_amount);
  :Создать order_items для каждого выпуска;
  :Очистить cart_items пользователя;
  :Сформировать квитанцию\n(текстовый файл);
  :Отдать квитанцию на скачивание;
  stop
endif
@enduml
